// Pyatakov Media — data model
// Production-ready schema for an independent international business media platform.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Users & Auth ───────────────────────────

enum Role {
  GUEST // not stored, default for unauthenticated
  SUBSCRIBER
  JOURNALIST
  EDITOR // chief editor / admin
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role      @default(SUBSCRIBER)
  emailVerified DateTime?
  image         String?

  // Author profile (for JOURNALIST / EDITOR)
  slug      String?  @unique
  position  String? // должность автора
  bio       String?  @db.Text
  twitter   String?
  telegram  String?
  linkedin  String?
  isActive  Boolean  @default(true)

  accounts  Account[]
  sessions  Session[]
  articles  Article[]       @relation("ArticleAuthor")
  revisions ArticleRevision[]
  comments  Comment[]
  bookmarks Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────── Taxonomy ───────────────────────────

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String // RU
  titleEn     String?
  description String?   @db.Text
  // Section kind drives template & ordering on the homepage / nav
  kind        SectionKind @default(ARTICLE)
  order       Int       @default(0)
  isVisible   Boolean   @default(true)
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  articles    Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
}

enum SectionKind {
  ARTICLE // Новости, Аналитика, Бизнес, Технологии, ИИ, Стартапы, Инвестиции, Геополитика, Мнения, Расследования, Колонки
  INTERVIEW
  PODCAST
  VIDEO
  RATING // Рейтинги
  SPECIAL // Спецпроекты
}

model Tag {
  id       String    @id @default(cuid())
  slug     String    @unique
  title    String
  articles ArticleTag[]

  createdAt DateTime @default(now())
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

// ─────────────────────────── Articles & Workflow ───────────────────────────

enum ArticleStatus {
  DRAFT
  IN_REVIEW // workflow согласования
  APPROVED
  SCHEDULED // запланирована
  PUBLISHED
  ARCHIVED
}

model Article {
  id        String        @id @default(cuid())
  slug      String        @unique
  status    ArticleStatus @default(DRAFT)

  // Core editorial fields
  title       String
  subtitle    String? // подзаголовок
  excerpt     String?   @db.Text // лид / анонс
  body        String    @db.Text // основной материал (HTML/Markdown)
  authorTitle String? // должность автора на момент публикации (snapshot)

  // Media
  coverImage  String?
  coverCaption String?
  gallery     Json? // [{url, caption}]
  videoUrl    String? // встроенное видео
  podcastUrl  String? // ссылка/файл подкаста

  // Reading
  readingMinutes Int? // время чтения
  sources        Json? // [{title, url}] — источники
  footnotes      Json? // [{marker, text}] — сноски

  // SEO / OpenGraph
  seoTitle       String?
  seoDescription String?  @db.Text
  ogTitle        String?
  ogDescription  String?  @db.Text
  ogImage        String?
  canonicalUrl   String?
  noindex        Boolean  @default(false)

  // Flags / placement
  isFeatured  Boolean @default(false) // блок важных событий
  isBreaking  Boolean @default(false) // бегущая лента
  isEditorPick Boolean @default(false) // редакционные подборки
  viewCount   Int     @default(0)

  // Localization
  locale String @default("ru")

  // Scheduling
  scheduledAt DateTime?
  publishedAt DateTime?

  // Relations
  authorId   String
  author     User     @relation("ArticleAuthor", fields: [authorId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  tags       ArticleTag[]
  comments   Comment[]
  revisions  ArticleRevision[]
  bookmarks  Bookmark[]

  // Type-specific extensions
  interview Interview?
  podcast   PodcastEpisode?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([isFeatured])
  @@index([locale])
}

// История изменений материалов
model ArticleRevision {
  id        String  @id @default(cuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  editorId  String
  editor    User    @relation(fields: [editorId], references: [id])
  // Snapshot
  title     String
  subtitle  String?
  body      String  @db.Text
  status    ArticleStatus
  note      String? // комментарий к правке / workflow
  createdAt DateTime @default(now())

  @@index([articleId])
}

// ─────────────────────────── Interview extension ───────────────────────────

model Interview {
  id        String  @id @default(cuid())
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  guestName  String // профиль гостя
  guestPhoto String?
  guestBio   String? @db.Text // биография гостя
  guestTitle String? // регалии гостя

  videoUrl    String? // видео-интервью
  transcript  String? @db.Text // текстовая расшифровка
  timecodes   Json? // [{time, label}] — таймкоды
  keyQuotes   Json? // [string] — ключевые цитаты
  // связанные материалы хранятся как массив slug'ов
  relatedSlugs Json?
}

// ─────────────────────────── Podcast extension ───────────────────────────

model PodcastEpisode {
  id        String  @id @default(cuid())
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  episodeNumber Int?
  duration      String? // "48:12"
  audioUrl      String?
  // карточки с ссылками на видео-платформы
  links         Json? // [{platform, url}]  youtube/spotify/apple/yandex
  seriesName    String? // категория/серия выпусков
}

// ─────────────────────────── Comments ───────────────────────────

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Comment {
  id        String        @id @default(cuid())
  articleId String
  article   Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String        @db.Text
  status    CommentStatus @default(PENDING)
  parentId  String?
  parent    Comment?      @relation("CommentThread", fields: [parentId], references: [id])
  replies   Comment[]     @relation("CommentThread")
  createdAt DateTime      @default(now())

  @@index([articleId, status])
}

// ─────────────────────────── Bookmarks ("Что читают сейчас" personalization) ───────────────────────────

model Bookmark {
  userId    String
  articleId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, articleId])
}

// ─────────────────────────── Advertising ───────────────────────────

enum AdSlot {
  HEADER
  SIDEBAR
  IN_ARTICLE
  FOOTER
  HOMEPAGE_HERO
}

model Ad {
  id        String   @id @default(cuid())
  title     String
  slot      AdSlot
  imageUrl  String?
  targetUrl String
  html      String?  @db.Text // custom creative
  isActive  Boolean  @default(true)
  weight    Int      @default(1)
  startsAt  DateTime?
  endsAt    DateTime?
  impressions Int    @default(0)
  clicks      Int    @default(0)
  createdAt DateTime @default(now())

  @@index([slot, isActive])
}

// ─────────────────────────── Media library ───────────────────────────

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  type      String // image | video | audio | document
  alt       String?
  caption   String?
  width     Int?
  height    Int?
  bytes     Int?
  createdAt DateTime @default(now())
}

// ─────────────────────────── Site settings / выходные данные СМИ ───────────────────────────

// Key/value store for masthead, legal & media-registration data (placeholders for now).
model SiteSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── Newsletter / Поддержка проекта leads ───────────────────────────

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("ru")
  confirmed Boolean  @default(false)
  createdAt DateTime @default(now())
}
