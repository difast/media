# ─── Database (Railway internal PostgreSQL) ───────────────────────────
# Set this in Railway → Variables. Example:
# postgresql://user:password@host:5432/railway
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pyatakov?schema=public"

# ─── Auth.js / NextAuth ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
# Public site URL (used by Auth.js, sitemap, RSS, OpenGraph)
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── AI (aitunnel) — recommendations + article generation ─────────────
AITUNNEL_API_KEY=""
AITUNNEL_BASE_URL="https://api.aitunnel.ru/v1"
AITUNNEL_MODEL="gpt-4o-mini"
# Live LLM ranking of the homepage "AI recommendations" block (costs tokens on
# every render). Off by default — uses a free deterministic blend instead.
HOMEPAGE_AI_RANK="false"

# ─── AI ingestion bot ─────────────────────────────────────────────────
# Free news aggregator (https://gnews.io). RSS sources work without a key.
GNEWS_API_KEY=""
# In-process scheduler: set to "true" to auto-run the bot on an interval.
INGEST_ENABLED="false"
INGEST_INTERVAL_MINUTES="60"
# NOTE: posts/day, time window, interval, on/off and auto-publish are managed
# in the CMS at /studio/automation (stored in DB). The vars below are only the
# initial defaults if nothing is set there yet.
INGEST_AUTO_PUBLISH="false"
INGEST_POSTS_PER_DAY="12"
INGEST_WINDOW_START="10"
INGEST_WINDOW_END="22"
INGEST_INTERVAL_MINUTES="60"
INGEST_TIMEZONE="Europe/Moscow"
# Items pulled per source per run (affects how many candidates the AI sees).
INGEST_LIMIT_PER_SOURCE="5"
# Token for the manual cron endpoint /api/cron/ingest (falls back to AUTH_SECRET).
CRON_SECRET=""

# ─── Telegram cross-posting ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""   # e.g. @pyatakovmedia or -100xxxxxxxxxx

# ─── Seed admin credentials (first run only) ──────────────────────────
SEED_ADMIN_EMAIL="editor@pyatakov.media"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
