# ─── Database (Railway internal PostgreSQL) ───────────────────────────
# Set this in Railway → Variables. Example:
# postgresql://user:password@host:5432/railway
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pyatakov?schema=public"

# ─── Auth.js / NextAuth ───────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
# Public site URL (used by Auth.js, sitemap, RSS, OpenGraph)
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── AI recommendations (aitunnel token — to be provided later) ───────
AITUNNEL_API_KEY=""
AITUNNEL_BASE_URL="https://api.aitunnel.ru/v1"

# ─── Seed admin credentials (first run only) ──────────────────────────
SEED_ADMIN_EMAIL="editor@pyatakov.media"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
